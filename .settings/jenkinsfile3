pipeline {
    agent {
        node {
            label 'built-in'
            customWorkspace '/mnt/war'
        }
    }

    stages {

        stage('SCM') {
            steps {
                sh '''
                rm -rf project
                git clone https://github.com/Hrishikeshkul/project.git
                '''
            }
        }

        stage('BUILD') {
            steps {
                sh '''
                cd /mnt/war/project
                mvn clean package
                '''
            }
        }
        stage('Docker Build') {
            steps {
                sh '''
                docker build -t loginwebapp:latest .
                '''
            }
        }

      stage('DEPLOY ON SLAVE') {
            agent {
                node {
                    label 'slave1'
                    customWorkspace '/mnt/jenkins-slave1'
                }
            }
      steps {
                sh '''
                docker rm -f loginwebapp || true
                docker run -d -p 8080:8080 --name loginwebapp loginwebapp:latest
                '''
            }
      }
      }
}
    
